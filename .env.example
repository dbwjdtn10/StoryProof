# ============================================
# StoryProof 환경 변수 예시
# cp .env.example .env 후 값을 채워서 사용
# ============================================

# ----- 환경 -----
ENVIRONMENT=development          # development | staging | production
DEBUG=false

# ----- 보안 (production에서는 반드시 변경) -----
SECRET_KEY=your-secret-key-change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ----- 데이터베이스 -----
DATABASE_URL=postgresql://storyproof:storyproof@localhost:5432/storyproof
POSTGRES_USER=storyproof
POSTGRES_PASSWORD=storyproof
POSTGRES_DB=storyproof

# ----- Redis / Celery -----
REDIS_HOST=localhost
REDIS_PORT=6379
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ----- AI API 키 (필수) -----
GOOGLE_API_KEY=your-google-ai-api-key       # Gemini + Imagen
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX_NAME=story-child-index-384

# ----- CORS (배포 도메인 추가) -----
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# ----- 선택 설정 -----
ENABLE_RERANKER=false            # true 시 리랭커 활성화 (메모리 사용 증가)
LOG_LEVEL=INFO
